{
  "name": "claude-feishu-bridge",
  "version": "0.1.0",
  "description": "Feishu-native control surface for Claude Code sessions.",
  "type": "module",
  "bin": {
    "claude-feishu-bridge": "./bin/claude-feishu-bridge.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "cli": "tsx src/index.ts --cli",
    "start": "node --enable-source-maps dist/index.js",
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test test/**/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.98",
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "axios": "^1.15.0"
  },
  "private": true
}
