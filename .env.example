# Root .env is only for local development (npm run dev / npm run cli).
# Production installs use:
#   ~/.config/claude-feishu-bridge/bridge.env  (secrets)
#   ~/.config/claude-feishu-bridge/config.json (tuning)
# See deploy/config/bridge.env.example and deploy/config/config.json for templates.

NODE_ENV=development

FEISHU_APP_ID=cli_PLACEHOLDER
FEISHU_APP_SECRET=PLACEHOLDER
FEISHU_BOT_OPEN_ID=ou_PLACEHOLDER
# FEISHU_STARTUP_NOTIFY_CHAT_ID=oc_PLACEHOLDER

# CLAUDE_BIN=/path/to/claude
# BRIDGE_CONFIG_JSON=/home/your/.config/claude-feishu-bridge/config.json

# Optional network/proxy settings for the bridge and spawned Claude runs.
# HTTP_PROXY=http://127.0.0.1:7897/
# HTTPS_PROXY=http://127.0.0.1:7897/
# ALL_PROXY=socks://127.0.0.1:7897/
# NO_PROXY=localhost,127.0.0.1,::1,.feishu.cn,open.feishu.cn
# http_proxy=http://127.0.0.1:7897/
# https_proxy=http://127.0.0.1:7897/
# all_proxy=socks://127.0.0.1:7897/
# no_proxy=localhost,127.0.0.1,::1,.feishu.cn,open.feishu.cn
# NODE_USE_ENV_PROXY=1
