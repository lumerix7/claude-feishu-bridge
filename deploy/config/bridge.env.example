NODE_ENV=production
NODE_USE_ENV_PROXY=1

FEISHU_APP_ID=replace-me
FEISHU_APP_SECRET=replace-me
FEISHU_BOT_OPEN_ID=replace-me
# Optional: send a "Bridge Ready" card to this chat on startup/reconnect.
# FEISHU_STARTUP_NOTIFY_CHAT_ID=oc_xxx

# Path to the Claude Code binary (default: claude on PATH).
# Use claude-run wrapper to enable NODE_USE_ENV_PROXY automatically.
CLAUDE_BIN=/path/to/claude

# Primary bridge config (project paths, Claude tuning, Feishu tuning).
BRIDGE_CONFIG_JSON=$HOME/.config/claude-feishu-bridge/config.json

# Optional network/proxy settings for the bridge process and spawned claude runs.
