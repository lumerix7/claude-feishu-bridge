<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.claude-feishu-bridge</string>
    <key>ProgramArguments</key>
    <array>
        <string>@START_SH_PATH@</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/claude-feishu-bridge.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/claude-feishu-bridge.err</string>
    <key>WorkingDirectory</key>
    <string>@HOME@</string>
</dict>
</plist>
